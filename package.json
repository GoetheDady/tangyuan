{
  "name": "tangyuan",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "pnpm --filter apps-desktop dev",
    "build": "pnpm --filter apps-desktop build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "verify:local": "pnpm lint && pnpm typecheck && pnpm test",
    "package:mac": "pnpm --filter apps-desktop package:mac",
    "smoke:packaged:mac": "pnpm --filter apps-desktop smoke:packaged:mac",
    "format": "pnpm -r format"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}
